{
  "info": {
    "_postman_id": "bm-api-collection-v1",
    "name": "Book Manager API",
    "description": "Complete API collection for the Book Manager MERN application — IFN636 Assessment 2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001", "type": "string" },
    { "key": "token",   "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Badr Alharbi\",\n  \"email\": \"badr@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login User",
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Login returns token', function () {", "  var json = pm.response.json();", "  pm.expect(json).to.have.property('token');", "  pm.collectionVariables.set('token', json.token);", "});"], "type": "text/javascript" }
          }],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"badr@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/auth/profile", "host": ["{{baseUrl}}"], "path": ["api","auth","profile"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/auth/profile", "host": ["{{baseUrl}}"], "path": ["api","auth","profile"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Badr Alharbi Updated\",\n  \"university\": \"QUT\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "Get All Books",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/books", "host": ["{{baseUrl}}"], "path": ["api","books"] }
          }
        },
        {
          "name": "Get Book by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/books/:id", "host": ["{{baseUrl}}"], "path": ["api","books",":id"], "variable": [{ "key": "id", "value": "BOOK_ID_HERE" }] }
          }
        },
        {
          "name": "Create Book",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/books", "host": ["{{baseUrl}}"], "path": ["api","books"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Clean Code\",\n  \"author\": \"Robert C. Martin\",\n  \"isbn\": \"978-0132350884\",\n  \"category\": \"Software Engineering\",\n  \"description\": \"A handbook of agile software craftsmanship\",\n  \"coverImage\": \"\",\n  \"status\": \"available\"\n}"
            }
          }
        },
        {
          "name": "Update Book",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/books/:id", "host": ["{{baseUrl}}"], "path": ["api","books",":id"], "variable": [{ "key": "id", "value": "BOOK_ID_HERE" }] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Clean Code (Updated)\",\n  \"status\": \"available\"\n}"
            }
          }
        },
        {
          "name": "Delete Book",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/books/:id", "host": ["{{baseUrl}}"], "path": ["api","books",":id"], "variable": [{ "key": "id", "value": "BOOK_ID_HERE" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Borrow Book",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/books/:id/borrow", "host": ["{{baseUrl}}"], "path": ["api","books",":id","borrow"], "variable": [{ "key": "id", "value": "BOOK_ID_HERE" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Return Book",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/books/:id/return", "host": ["{{baseUrl}}"], "path": ["api","books",":id","return"], "variable": [{ "key": "id", "value": "BOOK_ID_HERE" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Get Reviews for Book",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/books/:id/reviews", "host": ["{{baseUrl}}"], "path": ["api","books",":id","reviews"], "variable": [{ "key": "id", "value": "BOOK_ID_HERE" }] }
          }
        },
        {
          "name": "Add Review",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/books/:id/reviews", "host": ["{{baseUrl}}"], "path": ["api","books",":id","reviews"], "variable": [{ "key": "id", "value": "BOOK_ID_HERE" }] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Excellent book, highly recommended!\"\n}"
            }
          }
        },
        {
          "name": "Delete Review",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/books/:id/reviews/:reviewId", "host": ["{{baseUrl}}"], "path": ["api","books",":id","reviews",":reviewId"], "variable": [{ "key": "id", "value": "BOOK_ID_HERE" }, { "key": "reviewId", "value": "REVIEW_ID_HERE" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
