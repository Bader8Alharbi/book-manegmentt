{
  "info": {
    "_postman_id": "bm-api-collection-v3",
    "name": "Book Manager API",
    "description": "Complete self-contained API collection for BookVault — IFN636 Assessment 2.\n\nv3 changes vs v2:\n- Every request that needs an ID now captures it from earlier responses (no manual placeholders).\n- Requests are ordered so the Collection Runner produces 11/11 green by itself.\n- Each admin test (FT-24 through FT-31) sets up its own data via pre-request scripts.\n\nUsage:\n1. Set the baseUrl variable (http://localhost:5001 OR your ALB DNS).\n2. Make sure the admin user (admin@library.com / Admin@1234) exists — run 'npm run seed' on the backend once.\n3. Click Run Collection. Every assertion should pass.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",          "value": "http://localhost:5001", "type": "string" },
    { "key": "customerToken",    "value": "",                      "type": "string" },
    { "key": "adminToken",       "value": "",                      "type": "string" },
    { "key": "token",            "value": "",                      "type": "string" },
    { "key": "bookId",           "value": "",                      "type": "string" },
    { "key": "reviewId",         "value": "",                      "type": "string" },
    { "key": "adminUserId",      "value": "",                      "type": "string" },
    { "key": "throwawayUserId",  "value": "",                      "type": "string" },
    { "key": "randomSuffix",     "value": "",                      "type": "string" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level pre-request: generate a unique suffix once per run",
          "if (!pm.collectionVariables.get('randomSuffix') || pm.info.iteration === 0) {",
          "  pm.collectionVariables.set('randomSuffix', Date.now().toString());",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Register returns 201 (or 400 if user already exists)', function () {",
                "  pm.expect([201, 400]).to.include(pm.response.code);",
                "});"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Badr Alharbi\",\n  \"email\": \"badr@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login User (customer)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Login returns token', function () {",
                "  var json = pm.response.json();",
                "  pm.expect(json).to.have.property('token');",
                "  pm.collectionVariables.set('customerToken', json.token);",
                "  pm.collectionVariables.set('token', json.token);",
                "});"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"badr@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login as Admin",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Admin login returns admin token', function () {",
                "  var json = pm.response.json();",
                "  pm.expect(json).to.have.property('token');",
                "  pm.expect(json.role).to.eql('admin');",
                "  pm.collectionVariables.set('adminToken', json.token);",
                "});"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@library.com\",\n  \"password\": \"Admin@1234\"\n}"
            }
          }
        },
        {
          "name": "Get Profile",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/auth/profile", "host": ["{{baseUrl}}"], "path": ["api","auth","profile"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "Create Book (admin)",
          "event": [{
            "listen": "prerequest",
            "script": {
              "type": "text/javascript",
              "exec": [
                "// Generate a fresh per-request unique suffix so ISBN never collides across runs",
                "pm.collectionVariables.set('randomSuffix', Date.now().toString() + '-' + Math.floor(Math.random() * 100000));"
              ]
            }
          }, {
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                "pm.test('Response has _id', function () {",
                "  var json = pm.response.json();",
                "  pm.expect(json).to.have.property('_id');",
                "  pm.collectionVariables.set('bookId', json._id);",
                "});"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/books", "host": ["{{baseUrl}}"], "path": ["api","books"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman Test Book {{randomSuffix}}\",\n  \"author\": \"Test Suite\",\n  \"isbn\": \"isbn-{{randomSuffix}}\",\n  \"category\": \"Software Engineering\",\n  \"description\": \"Created automatically by Postman collection run\",\n  \"coverImage\": \"\",\n  \"status\": \"available\"\n}"
            }
          }
        },
        {
          "name": "Get All Books",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                "pm.test('Response is an array', function () {",
                "  pm.expect(pm.response.json()).to.be.an('array');",
                "});"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/books", "host": ["{{baseUrl}}"], "path": ["api","books"] }
          }
        },
        {
          "name": "Get Book by ID",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                "pm.test('Returned book id matches', function () {",
                "  pm.expect(pm.response.json()._id).to.eql(pm.collectionVariables.get('bookId'));",
                "});"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/books/{{bookId}}", "host": ["{{baseUrl}}"], "path": ["api","books","{{bookId}}"] }
          }
        },
        {
          "name": "Update Book (admin)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
              ]
            }
          }],
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/books/{{bookId}}", "host": ["{{baseUrl}}"], "path": ["api","books","{{bookId}}"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated by Postman test run\"\n}"
            }
          }
        },
        {
          "name": "Borrow Book (customer)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                "pm.test('Book status is borrowed', function () {",
                "  pm.expect(pm.response.json().status).to.eql('borrowed');",
                "});"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/books/{{bookId}}/borrow", "host": ["{{baseUrl}}"], "path": ["api","books","{{bookId}}","borrow"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Add Review (customer)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                "pm.test('Response has review _id', function () {",
                "  var json = pm.response.json();",
                "  pm.expect(json).to.have.property('_id');",
                "  pm.collectionVariables.set('reviewId', json._id);",
                "});"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/books/{{bookId}}/reviews", "host": ["{{baseUrl}}"], "path": ["api","books","{{bookId}}","reviews"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Excellent book - Postman automated review {{randomSuffix}}\"\n}"
            }
          }
        },
        {
          "name": "Get Reviews for Book",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/books/{{bookId}}/reviews", "host": ["{{baseUrl}}"], "path": ["api","books","{{bookId}}","reviews"] }
          }
        },
        {
          "name": "Delete Review (customer)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
              ]
            }
          }],
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/books/{{bookId}}/reviews/{{reviewId}}", "host": ["{{baseUrl}}"], "path": ["api","books","{{bookId}}","reviews","{{reviewId}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "description": "Admin-only endpoints. All five tests in this folder are self-contained — they set up their own data via pre-request scripts.",
      "item": [
        {
          "name": "Admin - Get All Users (FT-24, FT-25)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('FT-24: Status code is 200', function () {",
                "  pm.response.to.have.status(200);",
                "});",
                "pm.test('FT-25: Response is an array of users with no password field', function () {",
                "  var users = pm.response.json();",
                "  pm.expect(users).to.be.an('array');",
                "  pm.expect(users.length).to.be.above(0);",
                "  pm.expect(users[0]).to.not.have.property('password');",
                "  pm.expect(users[0]).to.have.property('email');",
                "  pm.expect(users[0]).to.have.property('role');",
                "});",
                "// Capture the admin user's _id for FT-28 (used later in this folder)",
                "var admin = pm.response.json().find(function (u) { return u.role === 'admin'; });",
                "if (admin) {",
                "  pm.collectionVariables.set('adminUserId', admin._id);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/admin/users", "host": ["{{baseUrl}}"], "path": ["api","admin","users"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Setup: Borrow book for FT-31",
          "event": [{
            "listen": "prerequest",
            "script": {
              "type": "text/javascript",
              "exec": [
                "// Make sure there's a borrowed book in the system before FT-31 runs.",
                "// We reuse the bookId captured earlier; if it's not borrowed anymore, borrow it now.",
                "var bookId = pm.collectionVariables.get('bookId');",
                "var customerToken = pm.collectionVariables.get('customerToken');",
                "if (!bookId) {",
                "  console.warn('No bookId captured — earlier requests must have failed');",
                "  return;",
                "}",
                "pm.sendRequest({",
                "  url: pm.collectionVariables.get('baseUrl') + '/api/books/' + bookId + '/borrow',",
                "  method: 'POST',",
                "  header: { 'Authorization': 'Bearer ' + customerToken }",
                "}, function (err, res) {",
                "  // 200 = freshly borrowed, 400 = already borrowed — both fine",
                "  console.log('Setup borrow response code:', res ? res.code : err);",
                "});"
              ]
            }
          }, {
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "// This setup-only request asserts the book is now in borrowed state",
                "pm.test('Setup: book is borrowed', function () {",
                "  // It's a no-op echo request — we just check the book status via the API.",
                "  pm.response.to.have.status(200);",
                "  var book = pm.response.json();",
                "  pm.expect(['borrowed','available']).to.include(book.status);",
                "});"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/books/{{bookId}}", "host": ["{{baseUrl}}"], "path": ["api","books","{{bookId}}"] },
            "header": []
          }
        },
        {
          "name": "Admin - Get Borrowed Books (FT-30, FT-31)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('FT-30: Status code is 200', function () {",
                "  pm.response.to.have.status(200);",
                "});",
                "pm.test('FT-31: At least one borrowed book has borrowedBy + createdBy populated', function () {",
                "  var books = pm.response.json();",
                "  pm.expect(books).to.be.an('array');",
                "  pm.expect(books.length).to.be.above(0);",
                "  // Find at least one book with both fields populated (some old records may have orphaned refs)",
                "  var populated = books.find(function (b) {",
                "    return b && b.status === 'borrowed'",
                "      && b.borrowedBy && typeof b.borrowedBy === 'object' && b.borrowedBy.email",
                "      && b.createdBy  && typeof b.createdBy  === 'object';",
                "  });",
                "  pm.expect(populated, 'expected at least one borrowed book with populated borrowedBy + createdBy').to.exist;",
                "});"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/admin/borrowed", "host": ["{{baseUrl}}"], "path": ["api","admin","borrowed"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Admin - Delete User (not found) (FT-27)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('FT-27: Returns 404 when user does not exist', function () {",
                "  pm.response.to.have.status(404);",
                "});"
              ]
            }
          }],
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/admin/users/000000000000000000000000", "host": ["{{baseUrl}}"], "path": ["api","admin","users","000000000000000000000000"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Admin - Delete User (admin refused) (FT-28)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('FT-28: Returns 400 when target is an admin', function () {",
                "  pm.response.to.have.status(400);",
                "});",
                "pm.test('Message says cannot delete admin', function () {",
                "  pm.expect(pm.response.text().toLowerCase()).to.include('admin');",
                "});"
              ]
            }
          }],
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/admin/users/{{adminUserId}}", "host": ["{{baseUrl}}"], "path": ["api","admin","users","{{adminUserId}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Setup: Register throwaway user for FT-26",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Setup: throwaway customer registered', function () {",
                "  pm.expect([201, 400]).to.include(pm.response.code);",
                "});",
                "// If we got 201, the new user's id is in the response.",
                "// If we got 400 (user already exists), we need to login + grab id.",
                "if (pm.response.code === 201) {",
                "  pm.collectionVariables.set('throwawayUserId', pm.response.json().id);",
                "  console.log('Throwaway user id:', pm.collectionVariables.get('throwawayUserId'));",
                "} else {",
                "  // Fallback: hit /api/admin/users with the admin token and find by email",
                "  var email = 'throwaway-' + pm.collectionVariables.get('randomSuffix') + '@example.com';",
                "  pm.sendRequest({",
                "    url: pm.collectionVariables.get('baseUrl') + '/api/admin/users',",
                "    method: 'GET',",
                "    header: { 'Authorization': 'Bearer ' + pm.collectionVariables.get('adminToken') }",
                "  }, function (err, res) {",
                "    if (res) {",
                "      var u = res.json().find(function (x) { return x.email === email; });",
                "      if (u) pm.collectionVariables.set('throwawayUserId', u._id);",
                "    }",
                "  });",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Throwaway User\",\n  \"email\": \"throwaway-{{randomSuffix}}@example.com\",\n  \"password\": \"temp1234\"\n}"
            }
          }
        },
        {
          "name": "Admin - Delete User (customer success) (FT-26)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('FT-26: Customer delete returns 200', function () {",
                "  pm.response.to.have.status(200);",
                "});",
                "pm.test('Response has confirmation message', function () {",
                "  pm.expect(pm.response.json()).to.have.property('message');",
                "});"
              ]
            }
          }],
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/admin/users/{{throwawayUserId}}", "host": ["{{baseUrl}}"], "path": ["api","admin","users","{{throwawayUserId}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Cleanup",
      "item": [
        {
          "name": "Return Book",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Cleanup: book returned successfully', function () {",
                "  pm.expect([200, 400]).to.include(pm.response.code);",
                "});"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/books/{{bookId}}/return", "host": ["{{baseUrl}}"], "path": ["api","books","{{bookId}}","return"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }]
          }
        },
        {
          "name": "Delete Book (admin)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Cleanup: book deleted', function () {",
                "  pm.expect([200, 404]).to.include(pm.response.code);",
                "});"
              ]
            }
          }],
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/books/{{bookId}}", "host": ["{{baseUrl}}"], "path": ["api","books","{{bookId}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        }
      ]
    }
  ]
}
