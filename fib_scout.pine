//@version=5
// FIB SCOUT — a live DEAL TICKET for whatever symbol is on your screen.
//
// This is not a backtest strategy: it is a heads-up display. Open any stock
// and the panel tells you instantly:
//   * STATE      - is there a setup right now, and what should you do
//   * the numbers - entry / stop / target prices and % away from here
//   * the size   - how many shares for YOUR account and risk %, position $
//   * the checks - uptrend, swing size, anchor volume, freshness: pass/fail
//   * the warning - if the wave is already stretched past the 1.272 extension
//     (measured on 13,000+ events: forward drift roughly HALVES there - the
//     "don't chase" zone; see backtest/FIB_WAVE_STUDY.md)
//
// Same engine as fib_strategy.pine (pivots + fib levels + trend SMA, no
// oscillators), same tuned levels (entry 0.318, stop 0.05 under the swing,
// target 1.0, runner potential 1.618). Long setups by default.
//
// STATES:
//   WAIT  (gray)   - no valid setup on this symbol right now
//   ARMED (yellow) - fresh setup; waiting for the pullback into the zone
//   BUY ZONE (green) - price is inside the entry zone NOW
//   BOUNCING (aqua)  - zone was tagged and price turned up; late but valid
//   EXTENDED (orange)- wave already past the 1.272 extension: do not chase
//   BROKEN / DONE / STALE (red/gray) - setup invalidated, played out, or old
//
// ALERTS (right-click chart -> Add alert -> condition = this indicator):
//   "New setup armed", "Price entered the buy zone", "Setup broken".
// Add the alert on each watchlist symbol once and TradingView becomes your
// scanner: your phone pings when any of them pulls back into its zone.
indicator("Fib Scout — deal ticket", overlay=true, max_lines_count=100, max_labels_count=50)

// ---------------- inputs ----------------
prd      = input.int(8,     "Pivot Period", minval=2)
entryFib = input.float(0.318, "Entry retracement level", step=0.01)
stopBuf  = input.float(0.05, "Stop buffer (x range beyond swing low)", step=0.01)
tgtFib   = input.float(1.0,  "Target (fib units)", options=[0.786, 1.0, 1.272, 1.618])
minRange = input.float(0.04, "Min swing size (range/anchor)", step=0.01)
maxRange = input.float(1.50, "Max swing size (range/anchor)", step=0.05)
entryWin = input.int(30,     "Bars a setup stays fresh", minval=1)
regimeLen= input.int(200,    "Trend SMA length", minval=20)
accountEq= input.float(10000, "Account size ($)", minval=100, step=500, group="Sizing")
riskPct  = input.float(1.0,  "Risk per trade (% of account)", minval=0.1, maxval=5.0, step=0.1, group="Sizing")
volLen   = input.int(20,     "Average-volume length", minval=5, group="Checks")
volMult  = input.float(1.3,  "Good anchor volume = x average", minval=1.0, step=0.1, group="Checks")
extWarn  = input.float(1.272,"Don't-chase extension level", options=[1.0, 1.272, 1.618], group="Checks")
showDraw = input.bool(true,  "Draw the setup zone on the chart")
bigText  = input.bool(true,  "Large panel text")

txtSz = bigText ? size.normal : size.small
smaT  = ta.sma(close, regimeLen)
avgVol= ta.sma(volume, volLen)

// ---------------- pivots (confirmed prd bars back) ----------------
ph = ta.pivothigh(high, prd, prd)
pl = ta.pivotlow(low,  prd, prd)
pivRelVol = na(avgVol[prd]) or avgVol[prd] == 0 ? na : volume[prd] / avgVol[prd]
var float phPrice = na
var int   phBar   = na
var float plPrice = na
var int   plBar   = na
var float plVol   = na
if not na(ph)
    phPrice := ph
    phBar   := bar_index - prd
if not na(pl)
    plPrice := pl
    plBar   := bar_index - prd
    plVol   := pivRelVol

// ---------------- latest long setup ----------------
var float sA0 = na   // swing low  (fib 0)
var float sA1 = na   // swing high (fib 1)
var float sE  = na
var float sS  = na
var float sT  = na
var int   sBar = na
var float sVol = na
var bool  fBroken = false
var bool  fDone   = false
var bool  fTouched= false

newSetup = false
if not na(pl) and not na(phPrice) and phBar < plBar and phPrice > plPrice
    rng = phPrice - plPrice
    relSz = rng / plPrice
    if relSz >= minRange and relSz <= maxRange
        sA0 := plPrice
        sA1 := phPrice
        sE  := plPrice + entryFib * rng
        sS  := plPrice - stopBuf * rng
        sT  := plPrice + tgtFib * rng
        sBar := bar_index
        sVol := plVol
        fBroken := false
        fDone   := false
        fTouched:= false
        newSetup := true

// ---------------- state machine ----------------
haveSetup = not na(sE)
age = haveSetup ? bar_index - sBar : 0
if haveSetup and not fBroken
    if low <= sS
        fBroken := true
    if high >= sT
        fDone := true
    if low <= sE and not fBroken
        fTouched := true

rngS   = haveSetup ? sA1 - sA0 : na
pFib   = haveSetup and rngS > 0 ? (close - sA0) / rngS : na          // where price sits on the grid
uptrend = na(smaT) or close > smaT
volOk   = not na(sVol) and sVol >= volMult
fresh   = age <= entryWin
inZone  = haveSetup and not fBroken and close <= sE and close > sS
extended= not na(pFib) and pFib >= extWarn

state = not haveSetup ? "WAIT" :
     fBroken ? "BROKEN" :
     fDone ? "DONE" :
     extended ? "EXTENDED" :
     inZone ? "BUY ZONE" :
     fTouched and close > sE ? "BOUNCING" :
     not fresh ? "STALE" : "ARMED"
stCol = state == "BUY ZONE" ? color.new(color.green, 0) :
     state == "ARMED" ? color.new(#b8860b, 0) :
     state == "BOUNCING" ? color.new(color.teal, 0) :
     state == "EXTENDED" ? color.new(color.orange, 20) :
     state == "BROKEN" ? color.new(color.red, 0) : color.new(color.gray, 20)
advice = state == "BUY ZONE" ? "Place the order NOW (limit " + str.tostring(sE, format.mintick) + ")" :
     state == "ARMED" ? "Set a limit at the entry and wait" :
     state == "BOUNCING" ? "Zone was tagged - late entry, smaller size" :
     state == "EXTENDED" ? "Past " + str.tostring(extWarn) + " ext: drift halves here - do not chase" :
     state == "BROKEN" ? "Structure failed - stand aside" :
     state == "DONE" ? "Move played out - wait for a new swing" :
     state == "STALE" ? "Setup too old - wait for a new swing" : "No valid swing yet"

// ---------------- deal ticket numbers ----------------
dist    = haveSetup ? sE - sS : na
rrTgt   = haveSetup and dist > 0 ? (sT - sE) / dist : na
shares  = haveSetup and dist > 0 ? math.floor(math.min(accountEq * riskPct / 100 / dist, accountEq / sE)) : na
posVal  = haveSetup and not na(shares) ? shares * sE : na
toEntry = haveSetup ? 100.0 * (sE / close - 1) : na

// ---------------- panel ----------------
f_pct(x) => (x >= 0 ? "+" : "") + str.tostring(x, "#.#") + "%"
var table tk = table.new(position.top_right, 2, 10, border_width=1, frame_width=2, frame_color=color.new(color.gray, 40))
if barstate.islast
    table.cell(tk, 0, 0, "FIB SCOUT", bgcolor=color.new(color.black, 20), text_color=color.white, text_size=txtSz)
    table.cell(tk, 1, 0, state, bgcolor=stCol, text_color=color.white, text_size=txtSz)
    table.cell(tk, 0, 1, "Advice", text_color=color.gray, text_size=size.tiny)
    table.cell(tk, 1, 1, advice, text_color=color.white, text_size=size.small)
    table.cell(tk, 0, 2, "Entry", text_color=color.yellow, text_size=txtSz)
    table.cell(tk, 1, 2, haveSetup ? str.tostring(sE, format.mintick) + "  (" + f_pct(toEntry) + " away)" : "-", text_color=color.yellow, text_size=txtSz)
    table.cell(tk, 0, 3, "Stop", text_color=color.red, text_size=txtSz)
    table.cell(tk, 1, 3, haveSetup ? str.tostring(sS, format.mintick) + "  (-" + str.tostring(100*(sE-sS)/sE, "#.#") + "% from entry)" : "-", text_color=color.red, text_size=txtSz)
    table.cell(tk, 0, 4, "Target", text_color=color.green, text_size=txtSz)
    table.cell(tk, 1, 4, haveSetup ? str.tostring(sT, format.mintick) + "  (R:R " + str.tostring(rrTgt, "#.##") + ")" : "-", text_color=color.green, text_size=txtSz)
    table.cell(tk, 0, 5, "Size", text_color=color.white, text_size=txtSz)
    table.cell(tk, 1, 5, haveSetup and not na(shares) ? str.tostring(shares, "#") + " sh  (~$" + str.tostring(posVal, "#") + ", risk $" + str.tostring(accountEq*riskPct/100, "#") + ")" : "-", text_color=color.white, text_size=txtSz)
    table.cell(tk, 0, 6, "Uptrend", text_color=color.gray, text_size=size.small)
    table.cell(tk, 1, 6, uptrend ? "✓ above " + str.tostring(regimeLen) + "SMA" : "✗ below " + str.tostring(regimeLen) + "SMA - longs off", text_color=uptrend ? color.lime : color.red, text_size=size.small)
    table.cell(tk, 0, 7, "Anchor vol", text_color=color.gray, text_size=size.small)
    table.cell(tk, 1, 7, na(sVol) ? "-" : (volOk ? "✓ " : "· ") + str.tostring(sVol, "#.0") + "x avg", text_color=volOk ? color.lime : color.gray, text_size=size.small)
    table.cell(tk, 0, 8, "Freshness", text_color=color.gray, text_size=size.small)
    table.cell(tk, 1, 8, haveSetup ? (fresh ? "✓ " : "✗ ") + str.tostring(age) + " bars old" : "-", text_color=fresh ? color.lime : color.red, text_size=size.small)
    table.cell(tk, 0, 9, "Wave pos.", text_color=color.gray, text_size=size.small)
    table.cell(tk, 1, 9, na(pFib) ? "-" : "price at " + str.tostring(pFib, "#.##") + " of the wave" + (extended ? "  ⚠ stretched" : ""), text_color=extended ? color.orange : color.white, text_size=size.small)

// ---------------- chart drawing (latest setup only) ----------------
var box  zbx = na
var line lnE = na
var line lnS = na
var line lnT = na
if newSetup and showDraw
    box.delete(zbx)
    line.delete(lnE)
    line.delete(lnS)
    line.delete(lnT)
    rightX = bar_index + entryWin
    zbx := box.new(bar_index, sE, rightX, sS, border_color=color.new(color.yellow, 60), bgcolor=color.new(color.yellow, 88))
    lnE := line.new(bar_index, sE, rightX, sE, color=color.yellow, width=2)
    lnS := line.new(bar_index, sS, rightX, sS, color=color.red, width=1, style=line.style_dashed)
    lnT := line.new(bar_index, sT, rightX, sT, color=color.green, width=2)
plot(smaT, "Trend SMA", color=color.new(color.orange, 55))

// ---------------- alerts ----------------
enterZoneEvt = haveSetup and not fBroken and fTouched and not fTouched[1]
brokenEvt    = fBroken and not fBroken[1]
alertcondition(newSetup,     "New setup armed",           "Fib Scout: new setup armed - check the deal ticket")
alertcondition(enterZoneEvt, "Price entered the buy zone", "Fib Scout: price just entered the buy zone")
alertcondition(brokenEvt,    "Setup broken",               "Fib Scout: setup invalidated (stop level traded)")
